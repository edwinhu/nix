#!/usr/bin/env bash
set -e

GREEN='\033[1;32m'
YELLOW='\033[1;33m'
RED='\033[1;31m'
NC='\033[0m'

# Get current username
USERNAME=$(whoami)
FLAKE_SYSTEM="darwinConfigurations.${USERNAME}.system"

export NIXPKGS_ALLOW_UNFREE=1

echo -e "${YELLOW}Building and switching configuration for user: ${USERNAME}${NC}"

# Use the current system's darwin-rebuild to build+switch in one evaluation
# (avoids evaluating the flake twice — once for nix build, again for darwin-rebuild)
DARWIN_REBUILD="/run/current-system/sw/bin/darwin-rebuild"
if [ ! -x "$DARWIN_REBUILD" ]; then
  echo -e "${RED}darwin-rebuild not found at $DARWIN_REBUILD, falling back to two-step build${NC}"
  nix --extra-experimental-features 'nix-command flakes' build .#$FLAKE_SYSTEM "$@"
  DARWIN_REBUILD="./result/sw/bin/darwin-rebuild"
fi

if [ "$(id -u)" -ne 0 ]; then
  sudo "$DARWIN_REBUILD" switch --flake .#${USERNAME} "$@"
else
  "$DARWIN_REBUILD" switch --flake .#${USERNAME} "$@"
fi

# Clean up result symlink if it exists (from fallback path)
[ -L ./result ] && unlink ./result

# Companion restart: darwin-rebuild already reloaded the plist (new wrapper path),
# which triggers RunAtLoad. Stop the auto-started instance, kill stale CLI sessions
# that hold old nix store paths, then start fresh — once, in order.
if launchctl print gui/$(id -u)/org.nixos.the-companion &>/dev/null; then
  echo -e "${YELLOW}Restarting the-companion (clean)...${NC}"
  launchctl kill SIGTERM gui/$(id -u)/org.nixos.the-companion 2>/dev/null || true
  sleep 2
  pkill -f 'claude.*--sdk-url.*localhost:3456' 2>/dev/null || true
  sleep 1
  launchctl kickstart gui/$(id -u)/org.nixos.the-companion
  # Wait for server to be healthy, then reload browser tabs so WebSockets reconnect
  sleep 3
  for i in 1 2 3 4 5; do
    if curl -s --connect-timeout 2 --max-time 5 http://localhost:3456/health | grep -q '"ok":true'; then
      # Reload companion tabs via CDP (Dia on port 9222)
      RELOADED=0
      for TAB_ID in $(curl -s http://localhost:9222/json/list 2>/dev/null | \
        python3 -c "import json,sys;[print(t['id']) for t in json.load(sys.stdin) if '3456' in t.get('url','')]" 2>/dev/null); do
        echo '{"id":1,"method":"Page.reload","params":{"ignoreCache":true}}' | \
          websocat "ws://localhost:9222/devtools/page/$TAB_ID" --one-message 2>/dev/null && \
          RELOADED=$((RELOADED + 1))
      done
      [ "$RELOADED" -gt 0 ] && echo -e "${YELLOW}Reloaded $RELOADED companion browser tab(s)${NC}"
      break
    fi
    sleep 2
  done
fi

echo -e "${GREEN}Switch to new generation complete!${NC}"
